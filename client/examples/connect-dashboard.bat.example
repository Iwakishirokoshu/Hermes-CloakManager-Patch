@echo off
REM === Hermes Dashboard (port 9119) ===
REM Make sure dashboard is running on VPS: ssh root@%VPS_HOST% "hermes dashboard start &"
REM
REM EDIT THESE TWO LINES:
set "VPS_HOST=YOUR_VPS_IP"
set "SSH_KEY=%USERPROFILE%\.ssh\id_ed25519"

set "LOCAL_PORT=9119"
set "REMOTE_PORT=9119"

echo  Hermes Dashboard: http://localhost:%LOCAL_PORT%
start "" "http://localhost:%LOCAL_PORT%"
ssh -i "%SSH_KEY%" -N -L %LOCAL_PORT%:127.0.0.1:%REMOTE_PORT% root@%VPS_HOST%
